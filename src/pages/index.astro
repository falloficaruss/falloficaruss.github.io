---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const sortedPosts = posts.map(post => ({
  ...post,
  slug: post.id.replace(/\.md$/, '')
})).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Home" description="A deep dive into minimalist cognitive framing and spatial metaphors in human consciousness.">
  <!-- Reading Progress Bar -->
  <div id="progress-container" class="fixed top-0 left-0 w-full h-1 z-50 pointer-events-none">
    <div id="progress-bar" class="h-full bg-charcoal-light/80 dark:bg-charcoal-dark/80 w-0 transition-all duration-100 ease-out origin-left"></div>
  </div>

  <!-- Ghost Navigation Bar -->
  <nav class="fixed w-full top-0 z-40 nav-ghost bg-paper-light/60 dark:bg-paper-dark/60 border-b border-transparent hover:border-gray-200 dark:hover:border-gray-800 transition-all duration-500">
    <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center font-sans">
      <a href="/" class="text-black dark:text-white tracking-[0.2em] text-xs font-semibold uppercase hover:opacity-70 transition-opacity">
        Aether & Form
      </a>
      <div class="flex items-center space-x-8">
        <span class="text-black dark:text-white text-xs uppercase tracking-wider font-medium opacity-60 transition-opacity hidden sm:block">Essays</span>
        <button id="theme-toggle" class="p-1 rounded-full text-black dark:text-white hover:bg-gray-200 dark:hover:bg-gray-800 transition-colors focus:outline-none">
          <span class="sr-only">Toggle Dark Mode</span>
          <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
          </svg>
          <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <header class="pt-32 pb-16 px-6 text-center max-w-3xl mx-auto">
    <h1 class="font-serif text-5xl md:text-6xl font-bold tracking-tight mb-6 text-black dark:text-white">
      Essays
    </h1>
    <p class="font-serif text-xl italic text-black dark:text-white leading-relaxed max-w-2xl mx-auto font-normal">
      Exploring the architecture of thought, silence, and memory.
    </p>
  </header>

  <!-- Posts Grid -->
  <main class="max-w-7xl mx-auto px-6 pb-24">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {sortedPosts.map((post) => (
        <article class="group">
          <a href={`/${post.slug}`} class="block">
            <div class="aspect-[4/3] overflow-hidden mb-6 bg-gray-100 dark:bg-gray-800">
              <img 
                src={post.data.image} 
                alt={post.data.title}
                class="w-full h-full object-cover filter brightness-[0.85] contrast-105 group-hover:brightness-100 group-hover:scale-105 transition-all duration-700"
              />
            </div>
            <div class="flex items-center space-x-2 text-[0.7rem] uppercase tracking-[0.2em] text-black dark:text-white mb-3">
              <span>{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
              <span class="opacity-50">✦</span>
              <span>{post.data.readTime}</span>
            </div>
            <h2 class="font-serif text-2xl font-bold leading-tight mb-3 text-black dark:text-white group-hover:opacity-70 transition-opacity">
              {post.data.title}
            </h2>
            <p class="font-serif text-black dark:text-white leading-relaxed line-clamp-3 opacity-80">
              {post.data.subtitle}
            </p>
          </a>
        </article>
      ))}
    </div>
  </main>

  <!-- Minimalist Footer -->
  <footer class="border-t border-gray-200 dark:border-gray-800 py-10 mt-auto">
    <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center font-sans text-xs uppercase tracking-widest text-black dark:text-white">
      <span class="mb-4 md:mb-0">© 2026 Aether & Form. All Rights Reserved.</span>
      <div class="flex space-x-6">
        <a href="#" class="hover:text-black dark:hover:text-white transition-colors">Twitter</a>
        <a href="#" class="hover:text-black dark:hover:text-white transition-colors">Instagram</a>
        <a href="#" class="hover:text-black dark:hover:text-white transition-colors">RSS</a>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const themeToggleDarkIcon = document.getElementById("theme-toggle-dark-icon");
      const themeToggleLightIcon = document.getElementById("theme-toggle-light-icon");
      const themeToggleBtn = document.getElementById("theme-toggle");

      if (document.documentElement.classList.contains("dark")) {
        themeToggleLightIcon?.classList.remove("hidden");
      } else {
        themeToggleDarkIcon?.classList.remove("hidden");
      }

      themeToggleBtn?.addEventListener("click", function () {
        themeToggleDarkIcon?.classList.toggle("hidden");
        themeToggleLightIcon?.classList.toggle("hidden");

        if (document.documentElement.classList.contains("dark")) {
          document.documentElement.classList.remove("dark");
          localStorage.setItem("color-theme", "light");
        } else {
          document.documentElement.classList.add("dark");
          localStorage.setItem("color-theme", "dark");
        }
      });

      const progressBar = document.getElementById("progress-bar");
      const updateProgress = () => {
        const scrollPosition = window.scrollY;
        const documentHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (documentHeight > 0 && progressBar) {
          progressBar.style.width = (scrollPosition / documentHeight) * 100 + "%";
        }
      };

      let isScrolling = false;
      window.addEventListener("scroll", () => {
        if (!isScrolling) {
          window.requestAnimationFrame(() => {
            updateProgress();
            isScrolling = false;
          });
          isScrolling = true;
        }
      });
      updateProgress();
    });
  </script>
</Layout>